---
// src/components/image-carousel.astro
import RindenmulchImage from "../assets/rindenmulch-hz.png";
import HelleHackschnitzelImage from "../assets/helle-hackschnitzel-01.png";
import WaldhackschnitzelImage from "../assets/whs.png";
import { Image } from "astro:assets";

interface CarouselImage {
    src: ImageMetadata;
    alt: string;
    title: string;
}

interface Props {
    images?: CarouselImage[];
}

// Default data tailored for Hackschnitzel if no props are passed
const defaultImages: CarouselImage[] = [
    {
        src: RindenmulchImage,
        alt: "Rindenmulch",
        title: "Rindenmulch",
    },
    {
        src: HelleHackschnitzelImage,
        alt: "Helle Hackschnitzel",
        title: "Helle Hackschnitzel",
    },
    {
        src: WaldhackschnitzelImage,
        alt: "Waldhackschnitzel",
        title: "Waldhackschnitzel",
    },
];

const { images = defaultImages } = Astro.props;
---

<image-carousel>
    <div
        class="relative w-full max-w-[800px] mx-auto overflow-hidden rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.1)] bg-[#f4f4f4]"
    >
        <div
            class="carousel-track flex transition-transform duration-500 ease-in-out w-full"
        >
            {
                images.map((image, index) => (
                    <div class="carousel-slide min-w-full relative">
                        <Image
                            src={image.src}
                            alt={image.alt}
                            loading={index === 0 ? "eager" : "lazy"}
                            class="w-full h-[400px] object-cover block"
                        />
                        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent text-white pt-[30px] px-5 pb-5 text-center">
                            <h3 class="m-0 mb-1.5 text-xl">{image.title}</h3>
                        </div>
                    </div>
                ))
            }
        </div>

        <button
            class="prev absolute top-1/2 -translate-y-1/2 bg-black/50 text-white border-none py-3 px-4 cursor-pointer text-2xl rounded transition-colors duration-200 z-10 hover:bg-black/80 left-2.5"
            aria-label="Previous image">&#10094;</button
        >
        <button
            class="next absolute top-1/2 -translate-y-1/2 bg-black/50 text-white border-none py-3 px-4 cursor-pointer text-2xl rounded transition-colors duration-200 z-10 hover:bg-black/80 right-2.5"
            aria-label="Next image">&#10095;</button
        >

        <div
            class="absolute bottom-[15px] left-1/2 -translate-x-1/2 flex gap-2 z-10"
        >
            {
                images.map((_, index) => (
                    <button
                        class={`dot w-3 h-3 rounded-full bg-white/50 border-none cursor-pointer transition-colors duration-200 hover:bg-white [&.active]:bg-white ${index === 0 ? "active" : ""}`}
                        data-index={index}
                        aria-label={`Go to slide ${index + 1}`}
                    />
                ))
            }
        </div>
    </div>
</image-carousel>

<script>
    class ImageCarousel extends HTMLElement {
        currentIndex: number;
        track: HTMLElement;
        slides: NodeListOf<Element>;
        dots: NodeListOf<Element>;

        constructor() {
            super();
            this.currentIndex = 0;
            this.track = this.querySelector(".carousel-track") as HTMLElement;
            this.slides = this.querySelectorAll(".carousel-slide");
            this.dots = this.querySelectorAll(".dot");

            const prevBtn = this.querySelector(".prev");
            const nextBtn = this.querySelector(".next");

            if (prevBtn)
                prevBtn.addEventListener("click", () => this.navigate(-1));
            if (nextBtn)
                nextBtn.addEventListener("click", () => this.navigate(1));

            this.dots.forEach((dot, index) => {
                dot.addEventListener("click", () => this.goToSlide(index));
            });
        }

        navigate(direction: number) {
            let newIndex = this.currentIndex + direction;
            if (newIndex < 0) newIndex = this.slides.length - 1;
            if (newIndex >= this.slides.length) newIndex = 0;
            this.goToSlide(newIndex);
        }

        goToSlide(index: number) {
            this.currentIndex = index;

            // Move track
            this.track.style.transform = `translateX(-${this.currentIndex * 100}%)`;

            // Update active dot state
            this.dots.forEach((dot) => dot.classList.remove("active"));
            if (this.dots[this.currentIndex]) {
                this.dots[this.currentIndex].classList.add("active");
            }
        }
    }

    // Register the custom element
    customElements.define("image-carousel", ImageCarousel);
</script>
